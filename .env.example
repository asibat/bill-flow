# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
EXTRACTION_PROVIDER=claude
# GEMINI_API_KEY=  # only needed if EXTRACTION_PROVIDER=gemini


# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_...
# The inbound email address users forward bills to (set up in Resend)
INBOUND_EMAIL_DOMAIN=billflow.app

# Supabase Storage — bucket for uploaded bill documents
SUPABASE_STORAGE_BUCKET=bill-documents

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@billflow.app

# Webhook secret to verify Resend inbound webhooks
RESEND_WEBHOOK_SECRET=your-webhook-secret
# Local-only: set to true to allow unsigned POSTs to /api/ingest/email for local testing.
RESEND_WEBHOOK_SKIP_VERIFICATION=false

# Cron job secret — set in Vercel project settings
CRON_SECRET=your-cron-secret

# Outbound email sender address
EMAIL_FROM_ADDRESS=BillFlow <noreply@billflow.app>

# Feature flags (true|false)
FEATURE_DASHBOARD_ANALYTICS=false
