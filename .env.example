# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
EXTRACTION_PROVIDER=<gemini|claude>
GEMINI_API_KEY=


# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_...
# The inbound email address users forward bills to (set up in Resend)
INBOUND_EMAIL_DOMAIN=billflow.app

# Supabase Storage — bucket for uploaded bill documents
SUPABASE_STORAGE_BUCKET=bill-documents

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Webhook secret to verify Resend inbound webhooks
RESEND_WEBHOOK_SECRET=your-webhook-secret

# PII microservice (Python/FastAPI) — for OCR + PII detection
PII_SERVICE_URL=http://localhost:8000

# Feature flags (true|false)
FEATURE_DASHBOARD_ANALYTICS=false


